# Copy this file to .env and fill in your own values.
# Nothing in this file should contain real credentials when committed.

# YouTube Data API keys (one or more; the pipeline rotates across them)
YOUTUBE_API_KEY_01=your_youtube_api_key_here

# Object storage (Cloudflare R2 or any S3-compatible store)
R2_ACCESS_KEY=your_access_key
R2_SECRET_KEY=your_secret_key
R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com

# Optional: Discord webhook for progress notifications
DISCORD_WEBHOOK_URL=
